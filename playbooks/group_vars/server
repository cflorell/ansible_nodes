---
branch: master

ssh_port: 22
ssh_users: root

# platform-specific
microcode_amd_install: false
microcode_intel_install: false

nfs_client: false
nfs_server: false
proxmox: false

docker: false

# node_exporter systemd collector — feeds node_systemd_unit_state, which the
# CertRenewal alert (files/prometheus-grafana/alert.rules.yml) watches on
# pve-daily-update.service. Additive; keeps the default collectors.
node_exporter_enabled_collectors:
  - systemd
