---
branch: master

ssh_port: 22
ssh_users: christoffer

# platform-specific
microcode_amd_install: false
microcode_intel_install: true

# application selection
starship: true
vscode: true

# Control-node path to the private secrets repo, used to source the personal
# age key onto this workstation. lookup('env', ...) always resolves on the
# control node (not the managed host), matching scripts/link-private-files.sh's
# default/override convention.
homelab_secrets_dir: "{{ lookup('env', 'HOMELAB_SECRETS_DIR') | default(lookup('env', 'HOME') + '/git/private/secrets', true) }}"