global:
  scrape_interval: 15s

rule_files:
  - "/etc/prometheus/alert.rules.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:9093']

scrape_configs:
  - job_name: 'prometheus'
    scrape_interval: 5s
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node_exporter'
    static_configs:
      - targets:
{# Scrape every inventory host that gets the node_exporter role — the same
   `node_exporter: true` host_vars flag playbook.yml gates the role on. #}
{% for host in groups['nodes'] + groups['server'] if hostvars[host]['node_exporter'] | default(false) %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}
