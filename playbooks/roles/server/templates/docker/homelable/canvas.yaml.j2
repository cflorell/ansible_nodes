---
# Homelable canvas — the desired state of the network map.
#
# This is the source of truth for topology. Ansible renders it, converts it to
# a CanvasSaveRequest and pushes it to the Homelable API (see
# tasks/nodes/homelable_canvas.yml). Nothing here is uploaded by hand.
#
# The container rank is NOT written by hand: every guest's containers (nodes
# and links) are generated from the `services` registry in
# playbooks/host_vars/<host> (schema documented in host_vars/docker), the same
# registry that feeds gatus and homepage. Only the skeleton — internet,
# gateway, hypervisors, guests/VMs — is declared here.
#
# Addresses are rendered from the Ansible inventory (hostvars) so no real IP is
# committed to this public repository — same pattern as homepage/services.yaml.j2.
#
# Node ids are derived from `label` (uuid5), so labels are the stable identity:
# renaming a label replaces the node and drops any manual edits made to it.
# Labels must be unique, which is why the promtail sidecars carry a
# `canvas.label` qualified with their host in the registry, and why qbittorrent
# is labelled after its service rather than its container_name (`torrent`,
# which would collide with the LXC node).
#
# Positions are NOT declared here. canvas-payload.json.j2 lays the tree out from
# the `links` below: children are packed left to right in declaration order and
# each parent is centred over its own children. Add a service to a host's
# registry and the layout re-flows on the next run. That also means registry
# declaration order is what controls placement within a host's column.
#
# The tree is internet -> gateway -> hypervisor -> guest -> container. Services
# that run on a hypervisor directly (scrutiny, jellyfin) hang off the proxmox
# node, so they sit at the guest rank rather than the container rank.
#
# Containers whose registry entry has a check get an http/tcp check against
# their published port; purely internal ones (check: none — databases, workers,
# log shippers) get no check at all, so they stay "unknown" grey rather than
# claiming to be up. `checkMethod: none` is deliberately avoided — the backend
# treats it as always-online.
#
# Schema: https://github.com/Pouzor/homelable -> frontend/src/types/yaml.ts
{% set docker_host = hostvars.get('docker', {}).get('ansible_host', 'docker') %}
{% set authentik_host = hostvars.get('authentik', {}).get('ansible_host', 'authentik') %}
{% set immich_host = hostvars.get('immich', {}).get('ansible_host', 'immich') %}
{% set media_host = hostvars.get('media', {}).get('ansible_host', 'media') %}
{% set media2_host = hostvars.get('media2', {}).get('ansible_host', 'media2') %}
{% set prometheus_grafana_host = hostvars.get('prometheus-grafana', {}).get('ansible_host', 'prometheus-grafana') %}
{% set proxmox1_host = hostvars.get('proxmox1', {}).get('ansible_host', 'proxmox1') %}
{% set proxmox2_host = hostvars.get('proxmox2', {}).get('ansible_host', 'proxmox2') %}
{% set proxmox3_host = hostvars['proxmox3'].ansible_host if 'proxmox3' in hostvars else 'proxmox3' %}
{% set torrent_host = hostvars.get('torrent', {}).get('ansible_host', 'torrent') %}
{% set runner_host = hostvars.get('runner', {}).get('ansible_host', 'runner') %}
{% set kube_control_host = hostvars['kube-control'].ansible_host if 'kube-control' in hostvars else hostvars['kubernetes-control'].ansible_host if 'kubernetes-control' in hostvars else 'kube-control' %}
{% set kube_node1_host = hostvars['kube-node1'].ansible_host if 'kube-node1' in hostvars else hostvars['kubernetes-node1'].ansible_host if 'kubernetes-node1' in hostvars else 'kube-node1' %}
{% set kube_node2_host = hostvars['kube-node2'].ansible_host if 'kube-node2' in hostvars else hostvars['kubernetes-node2'].ansible_host if 'kubernetes-node2' in hostvars else 'kube-node2' %}
{% set kube_node3_host = hostvars['kube-node3'].ansible_host if 'kube-node3' in hostvars else hostvars['kubernetes-node3'].ansible_host if 'kubernetes-node3' in hostvars else 'kube-node3' %}
{# OPNsense and Home Assistant are not Ansible-managed, so they have no hostvars
   entry. Set homelable_gateway_ip / homelable_homeassistant_ip in secrets.vault
   to pin them; otherwise they fall back to a DNS name resolved by OPNsense. #}
{% set homeassistant_host = hostvars['homeassistant'].ansible_host if 'homeassistant' in hostvars else homelable_homeassistant_ip | default('homeassistant') %}
{% set opnsense_host = hostvars['opnsense'].ansible_host if 'opnsense' in hostvars else homelable_gateway_ip | default('OPNsense.localdomain') %}
{# service_links: the `links` entries for one host's registry services.
   container_nodes: the docker_container nodes for one host's registry
   services. Entries with `canvas: false` are skipped entirely; entries with
   `check: none` or `canvas.check: false` are drawn without a check. #}
{% macro service_links(host) %}
{% for svc in hostvars[host]['services'] | default([]) if svc.canvas | default({}) is mapping %}
    - label: {{ (svc.canvas | default({})).label | default(svc.name) }}
      linkType: virtual
{% endfor %}
{% endmacro %}
{% macro container_nodes(host) %}
{% set addr = hostvars[host].ansible_host %}
{% for svc in hostvars[host]['services'] | default([]) if svc.canvas | default({}) is mapping %}
{% set c = svc.canvas | default({}) %}
{% set method = c.method | default(svc.check | default('none')) %}

- nodeType: docker_container
  label: {{ c.label | default(svc.name) }}
  nodeIcon: {{ c.icon | default('server') }}
{% if svc.check | default('none') != 'none' and c.check | default(true) %}
  ipAddress: "{{ addr }}"
  checkMethod: {{ method }}
{% if method == 'http' %}
  checkTarget: "http://{{ addr }}:{{ svc.port }}"
{% else %}
  checkTarget: "{{ addr }}:{{ svc.port }}"
{% endif %}
{% endif %}
{% if c.notes is defined %}
  notes: {{ c.notes | to_json }}
{% endif %}
{% endfor %}
{% endmacro %}

# --- Edge ---------------------------------------------------------------

- nodeType: isp
  label: Internet
  nodeIcon: globe
  checkMethod: ping
  checkTarget: "1.1.1.1"
  notes: WAN uplink. Public address is kept dynamic by porkbun-ddns on the docker host.
  links:
    - label: OPNsense
      linkType: ethernet

- nodeType: firewall
  label: OPNsense
  nodeIcon: brand:opnsense
  hostname: OPNsense.localdomain
  ipAddress: "{{ opnsense_host }}"
  checkMethod: ping
  notes: >-
    Router, firewall and DHCP/DNS for the homelab LAN. Web UI uses a self-
    signed certificate, so this node is checked with ping.
  links:
    - label: proxmox1
      linkType: ethernet
    - label: proxmox2
      linkType: ethernet
    - label: proxmox3
      linkType: ethernet

# --- Hypervisors --------------------------------------------------------

- nodeType: proxmox
  label: proxmox1
  nodeIcon: brand:proxmox
  hostname: proxmox
  ipAddress: "{{ proxmox1_host }}"
  checkMethod: tcp
  checkTarget: "{{ proxmox1_host }}:8006"
  notes: >-
    Proxmox VE node "proxmox" — main hypervisor: most of the LXC service stack
    plus the GitLab runner VM. Checked over TCP/8006 because the API
    certificate is self-signed.
  links:
    - label: docker
      linkType: virtual
    - label: authentik
      linkType: virtual
    - label: prometheus-grafana
      linkType: virtual
    - label: media
      linkType: virtual
    - label: torrent
      linkType: virtual
    - label: media2
      linkType: virtual
    - label: runner
      linkType: virtual
{{ service_links('proxmox1') }}
- nodeType: proxmox
  label: proxmox2
  nodeIcon: brand:proxmox
  hostname: proxmox2
  ipAddress: "{{ proxmox2_host }}"
  checkMethod: tcp
  checkTarget: "{{ proxmox2_host }}:8006"
  notes: >-
    Proxmox VE node "proxmox2" — hosts Immich and the Home Assistant VM, and
    runs Jellyfin directly on the host. Checked over TCP/8006 because the API
    certificate is self-signed.
  links:
    - label: immich
      linkType: virtual
    - label: homeassistant
      linkType: virtual
{{ service_links('proxmox2') }}
- nodeType: proxmox
  label: proxmox3
  nodeIcon: brand:proxmox
  hostname: proxmox3
  ipAddress: "{{ proxmox3_host }}"
  checkMethod: tcp
  checkTarget: "{{ proxmox3_host }}:8006"
  notes: >-
    Proxmox VE node "proxmox3" — dedicated to the kubeadm cluster VMs. Checked
    over TCP/8006 because the API certificate is self-signed.
  links:
    - label: kube-control
      linkType: virtual
    - label: kube-node1
      linkType: virtual
    - label: kube-node2
      linkType: virtual
    - label: kube-node3
      linkType: virtual

# --- proxmox1 guests ----------------------------------------------------

- nodeType: lxc
  label: docker
  nodeIcon: brand:docker
  ipAddress: "{{ docker_host }}"
  checkMethod: http
  checkTarget: "http://{{ docker_host }}:3000"
  cpuCore: 2
  ram: 2
  disk: 16
  notes: >-
    LXC 100 on proxmox1. Docker host for the front-of-house stack — dashboard,
    uptime, reverse proxy, alerting and this canvas.
  links:
{{ service_links('docker') }}
{{ container_nodes('docker') }}

- nodeType: lxc
  label: authentik
  nodeIcon: brand:authentik
  ipAddress: "{{ authentik_host }}"
  checkMethod: http
  checkTarget: "http://{{ authentik_host }}:9000"
  cpuCore: 2
  ram: 2
  disk: 8
  notes: >-
    LXC 101 on proxmox1. Single-sign-on for the homelab.
  links:
{{ service_links('authentik') }}
{{ container_nodes('authentik') }}

- nodeType: lxc
  label: prometheus-grafana
  nodeIcon: brand:grafana
  ipAddress: "{{ prometheus_grafana_host }}"
  checkMethod: http
  checkTarget: "http://{{ prometheus_grafana_host }}:3000"
  cpuCore: 2
  ram: 2
  disk: 32
  notes: >-
    LXC 103 on proxmox1. Metrics, logs and alerting. Alerts leave through the
    Signal webhook on the docker host.
  links:
{{ service_links('prometheus-grafana') }}
{{ container_nodes('prometheus-grafana') }}

- nodeType: lxc
  label: media
  nodeIcon: brand:jellyseerr
  ipAddress: "{{ media_host }}"
  checkMethod: http
  checkTarget: "http://{{ media_host }}:5055"
  cpuCore: 8
  ram: 4
  disk: 16
  notes: >-
    LXC 104 on proxmox1. Media requests, playback tracing and the ebook
    library.
  links:
{{ service_links('media') }}
{{ container_nodes('media') }}

- nodeType: lxc
  label: torrent
  nodeIcon: brand:qbittorrent
  ipAddress: "{{ torrent_host }}"
  checkMethod: http
  checkTarget: "http://{{ torrent_host }}:8080"
  cpuCore: 8
  ram: 2
  disk: 16
  notes: >-
    LXC 106 on proxmox1. All traffic egresses through a VPN tunnel, so this
    host may not answer a plain LAN scan.
  links:
{{ service_links('torrent') }}
{{ container_nodes('torrent') }}

- nodeType: lxc
  label: media2
  nodeIcon: brand:paperless-ngx
  ipAddress: "{{ media2_host }}"
  checkMethod: http
  checkTarget: "http://{{ media2_host }}:8000"
  cpuCore: 2
  ram: 2
  disk: 24
  notes: >-
    LXC 107 on proxmox1. Document archive and game library.
  links:
{{ service_links('media2') }}
{{ container_nodes('media2') }}

- nodeType: vm
  label: runner
  nodeIcon: brand:gitlab
  ipAddress: "{{ runner_host }}"
  checkMethod: ssh
  cpuCore: 4
  ram: 4
  disk: 128
  notes: >-
    VM 108 on proxmox1. GitLab shell runner that provisions this homelab. Host
    CPU passthrough for nested virtualisation. No containers of its own — it
    runs jobs. Checked over SSH.

# --- proxmox1: services on the hypervisor itself -------------------------
{{ container_nodes('proxmox1') }}

# --- proxmox2 guests ----------------------------------------------------

- nodeType: lxc
  label: immich
  nodeIcon: brand:immich
  ipAddress: "{{ immich_host }}"
  checkMethod: http
  checkTarget: "http://{{ immich_host }}:2283"
  cpuCore: 6
  ram: 4
  disk: 24
  notes: >-
    LXC 102 on proxmox2. Photo library with its own ML worker.
  links:
{{ service_links('immich') }}
{{ container_nodes('immich') }}

- nodeType: vm
  label: homeassistant
  nodeIcon: brand:home-assistant
  ipAddress: "{{ homeassistant_host }}"
  checkMethod: http
  checkTarget: "http://{{ homeassistant_host }}:8123"
  cpuCore: 2
  ram: 4
  disk: 32
  notes: >-
    VM 105 on proxmox2 (HAOS appliance image, "haosova"). Home Assistant
    :8123. Built by Terraform but deliberately not managed by Ansible, so it
    has no inventory entry and no compose stack here — set
    homelable_homeassistant_ip in secrets.vault to pin its address.

# --- proxmox2: services on the hypervisor itself -------------------------
{{ container_nodes('proxmox2') }}

# --- proxmox3 guests: kubeadm cluster -----------------------------------

- nodeType: vm
  label: kube-control
  nodeIcon: brand:kubernetes
  ipAddress: "{{ kube_control_host }}"
  checkMethod: tcp
  checkTarget: "{{ kube_control_host }}:6443"
  cpuCore: 2
  ram: 4
  disk: 32
  notes: >-
    VM 120 on proxmox3. kubeadm control plane, Kubernetes v1.36, Flannel CNI
    (pod CIDR 10.244.0.0/16). API server on :6443 — checked over TCP because
    the certificate is signed by the cluster CA. Workloads live in Kubernetes,
    not in compose files, so no services are drawn under it.

- nodeType: vm
  label: kube-node1
  nodeIcon: brand:kubernetes
  ipAddress: "{{ kube_node1_host }}"
  checkMethod: ssh
  cpuCore: 2
  ram: 4
  disk: 32
  notes: >-
    VM 121 on proxmox3. Kubernetes worker, containerd runtime. Joined to kube-
    control.

- nodeType: vm
  label: kube-node2
  nodeIcon: brand:kubernetes
  ipAddress: "{{ kube_node2_host }}"
  checkMethod: ssh
  cpuCore: 2
  ram: 4
  disk: 32
  notes: >-
    VM 122 on proxmox3. Kubernetes worker, containerd runtime. Joined to kube-
    control.

- nodeType: vm
  label: kube-node3
  nodeIcon: brand:kubernetes
  ipAddress: "{{ kube_node3_host }}"
  checkMethod: ssh
  cpuCore: 2
  ram: 4
  disk: 32
  notes: >-
    VM 123 on proxmox3. Kubernetes worker, containerd runtime. Joined to kube-
    control.
