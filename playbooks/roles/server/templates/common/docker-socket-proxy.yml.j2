  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:v0.4.2
    container_name: docker-socket-proxy
    environment:
      # Read-only: only what whats-up-docker needs to list containers/images.
      CONTAINERS: 1
      IMAGES: 1
      PING: 1
      VERSION: 1
    ports:
      - "{{ docker_socket_proxy_port }}:2375"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    # Docker's default docker-default AppArmor profile denies the unix
    # socketpair HAProxy's master/worker CLI needs, which crash-loops this
    # container (exit 1, "Cannot create worker master CLI socketpair") on
    # bare-metal Proxmox hosts where AppArmor is actually enforced.
    security_opt:
      - apparmor:unconfined
    restart: unless-stopped
