---
# For configuration options and examples, please see:
# https://gethomepage.dev/configs/services/
#
# The Home/Monitor/Multimedia/Library/Tools groups are generated from the
# `services` registry in playbooks/host_vars/<host> (schema documented in
# host_vars/docker) — add a service there and its tile appears here. Tiles for
# things that are not registry services (the Home Assistant VM, the
# hypervisors, the runner and kubernetes VMs) stay hand-written below.
{% set proxmox1_host = hostvars.get('proxmox1', {}).get('ansible_host', 'proxmox1') %}
{% set proxmox2_host = hostvars.get('proxmox2', {}).get('ansible_host', 'proxmox2') %}
{% set proxmox3_host = hostvars['proxmox3'].ansible_host if 'proxmox3' in hostvars else 'proxmox3' %}
{% set runner_host = hostvars.get('runner', {}).get('ansible_host', 'runner') %}
{% set kube_control_host = hostvars['kube-control'].ansible_host if 'kube-control' in hostvars else hostvars['kubernetes-control'].ansible_host if 'kubernetes-control' in hostvars else 'kube-control' %}
{% set kube_node1_host = hostvars['kube-node1'].ansible_host if 'kube-node1' in hostvars else hostvars['kubernetes-node1'].ansible_host if 'kubernetes-node1' in hostvars else 'kube-node1' %}
{% set kube_node2_host = hostvars['kube-node2'].ansible_host if 'kube-node2' in hostvars else hostvars['kubernetes-node2'].ansible_host if 'kubernetes-node2' in hostvars else 'kube-node2' %}
{% set kube_node3_host = hostvars['kube-node3'].ansible_host if 'kube-node3' in hostvars else hostvars['kubernetes-node3'].ansible_host if 'kubernetes-node3' in hostvars else 'kube-node3' %}
{% set homeassistant_host = hostvars['homeassistant'].ansible_host if 'homeassistant' in hostvars else 'homeassistant' %}
{% set ns = namespace(tiles=[]) %}
{% for host in groups['nodes'] + groups['server'] %}
{% set addr = hostvars[host].ansible_host %}
{% for svc in hostvars[host]['services'] | default([]) if svc.homepage is defined %}
{% set hp = svc.homepage %}
{% set href = 'http://' ~ addr ~ ':' ~ svc.port ~ '/' %}
{% set tile = {'icon': hp.icon, 'href': href, 'description': hp.description} %}
{% if hp.widget is defined %}
{% set _ = tile.update({'widget': hp.widget | combine({'url': hp.widget.url | default(href)})}) %}
{% endif %}
{% if hp.extra is defined %}
{% set _ = tile.update(hp.extra) %}
{% endif %}
{% set _ = ns.tiles.append({'name': hp.name, 'group': hp.group, 'weight': hp.weight | default(100), 'tile': tile}) %}
{% endfor %}
{% endfor %}
{% for grp in ['Home', 'Monitor', 'Multimedia', 'Library', 'Tools'] %}

- {{ grp }}:
{% for t in ns.tiles | selectattr('group', 'equalto', grp) | sort(attribute='weight') %}
    - {{ t.name }}:
{{ t.tile | to_nice_yaml(indent=2) | indent(8, true) }}
{%- endfor %}
{% if grp == 'Home' %}
    - Home Assistant:
        icon: home-assistant.png
        href: http://{{ homeassistant_host }}:8123/
        description: Home automation VM
        widget:
          type: homeassistant
          url: http://{{ homeassistant_host }}:8123/
          key: "{{ homeassistant_access_token | default('changeme') }}"
        proxmoxNode: proxmox2
        proxmoxVMID: 105
        proxmoxType: qemu
{% endif %}
{% endfor %}

- Infrastructure:
    - Proxmox:
        icon: proxmox.png
        href: https://{{ proxmox1_host }}:8006/
        description: Proxmox node
        widget:
          type: proxmox
          url: https://{{ proxmox1_host }}:8006/
          username: "root@pam!{{ proxmox_ansible_api_token_id | default('ansible-token') }}"
          password: "{{ proxmox_ansible_api_token_secret | default('changeme') }}"
          node: proxmox
    - Proxmox 2:
        icon: proxmox.png
        href: https://{{ proxmox2_host }}:8006/
        description: Proxmox node
        widget:
          type: proxmox
          url: https://{{ proxmox2_host }}:8006/
          username: "root@pam!{{ proxmox_ansible_api_token_id | default('ansible-token') }}"
          password: "{{ proxmox_ansible_api_token_secret | default('changeme') }}"
          node: proxmox2
    - Proxmox 3:
        icon: proxmox.png
        href: https://{{ proxmox3_host }}:8006/
        description: Proxmox node
        widget:
          type: proxmox
          url: https://{{ proxmox3_host }}:8006/
          username: "root@pam!{{ proxmox_ansible_api_token_id | default('ansible-token') }}"
          password: "{{ proxmox_ansible_api_token_secret | default('changeme') }}"
          node: proxmox3
    - Runner:
        icon: gitlab.png
        href: ssh://root@{{ runner_host }}
        description: GitLab runner VM
        proxmoxNode: proxmox
        proxmoxVMID: 108
        proxmoxType: qemu
    - Kubernetes Control:
        icon: kubernetes.png
        href: ssh://root@{{ kube_control_host }}
        description: Kubernetes control-plane VM
        proxmoxNode: proxmox3
        proxmoxVMID: 120
        proxmoxType: qemu
    - Kubernetes Node 1:
        icon: kubernetes.png
        href: ssh://root@{{ kube_node1_host }}
        description: Kubernetes worker VM
        proxmoxNode: proxmox3
        proxmoxVMID: 121
        proxmoxType: qemu
    - Kubernetes Node 2:
        icon: kubernetes.png
        href: ssh://root@{{ kube_node2_host }}
        description: Kubernetes worker VM
        proxmoxNode: proxmox3
        proxmoxVMID: 122
        proxmoxType: qemu
    - Kubernetes Node 3:
        icon: kubernetes.png
        href: ssh://root@{{ kube_node3_host }}
        description: Kubernetes worker VM
        proxmoxNode: proxmox3
        proxmoxVMID: 123
        proxmoxType: qemu
