# Homelable backend secrets — managed by Ansible, do not edit on the host.
# See https://github.com/Pouzor/homelable/blob/main/.env.example

# Session/JWT signing key.
SECRET_KEY={{ homelable_secret_key }}

# Login credentials. Password hash is bcrypt; keep the single quotes so Docker
# does not misinterpret the $ characters in the hash.
AUTH_USERNAME={{ homelable_auth_username }}
AUTH_PASSWORD_HASH='{{ homelable_auth_password_hash }}'
