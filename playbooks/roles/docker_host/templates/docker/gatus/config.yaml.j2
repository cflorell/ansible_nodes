web:
  port: 8080

ui:
  title: "Homelab Status"
  default-sort-by: group

alert-defaults: &alert-defaults
  description: "homelab monitoring"
  send-on-resolved: true
  failure-threshold: 3
  success-threshold: 2

notify-all: &notify-all
  - type: telegram
  - type: signal

connected-conditions: &connected-conditions
  - "[CONNECTED] == true"

http-conditions: &http-conditions
  - "[STATUS] < 400"

alerting:
  telegram:
    token: "{{ telegram_api_token }}"
    id: "{{ telegram_chat_id }}"
    default-alert: *alert-defaults

  signal:
    api-url: "http://signal-cli-rest-api:8080"
    number: "{{ signal_alertmanager_number }}"
    recipients:
{% for recipient in signal_alertmanager_recipients %}
      - "{{ recipient }}"
{% endfor %}
    default-alert: *alert-defaults

endpoints:
  # --- Nodes managed by terraform_nodes (ping) ---
{% for host in groups['nodes'] %}
  - name: "{{ host }}"
    group: nodes
    url: "icmp://{{ hostvars[host].ansible_host }}"
    interval: 1m
    conditions: *connected-conditions
    alerts: *notify-all
{% endfor %}
{% for host in groups['kubernetes_control'] + groups['kubernetes_workers'] %}
  - name: "{{ host }}"
    group: nodes
    url: "icmp://{{ hostvars[host].ansible_host }}"
    interval: 1m
    conditions: *connected-conditions
    alerts: *notify-all
{% endfor %}

  # --- Proxmox hypervisors (inventory group [server]) ---
{% for host in groups['server'] %}
  - name: "{{ host }}"
    group: server
    url: "icmp://{{ hostvars[host].ansible_host }}"
    interval: 1m
    conditions: *connected-conditions
    alerts: *notify-all
{% endfor %}

  # --- Proxmox web UI/API (pveproxy) — ICMP only proves the host is up; this
  #     catches pveproxy/pvedaemon wedged while it still pings. Connects by IP,
  #     so client.insecure is required (the LE cert is for the FQDN).
{% for host in groups['server'] %}
  - name: "{{ host }}-pveproxy"
    group: server
    url: "https://{{ hostvars[host].ansible_host }}:8006"
    interval: 5m
    client:
      insecure: true
    conditions:
      - "[STATUS] < 500"
      - "[CERTIFICATE_EXPIRATION] > {{ gatus_cert_min_expiry | default('336h') }}"
    alerts: *notify-all
{% endfor %}

  # --- Home Assistant OS VM (terraform_nodes/haosova.tf, not Ansible-managed) ---
  - name: home-assistant
    group: haosova
    url: "http://{{ hostvars['homeassistant'].ansible_host if 'homeassistant' in hostvars else homelable_homeassistant_ip | default('homeassistant') }}:8123"
    interval: 2m
    conditions: *http-conditions
    alerts: *notify-all

  # --- OPNsense gateway — nothing else here checks the router itself, and
  #     it's the single point of failure for the whole LAN plus WAN/DDNS.
  - name: opnsense
    group: server
    url: "icmp://{{ opnsense_gateway_ip | default('192.168.2.1') }}"
    interval: 1m
    conditions: *connected-conditions
    alerts: *notify-all

  # --- Per-service checks, generated from the `services` registry in
  #     playbooks/host_vars/<host> (schema documented in host_vars/docker).
  #     Containers without a published port carry check: none there and are
  #     deliberately absent here, so they stay unmonitored by design rather
  #     than by omission. ---
{% for host in groups['nodes'] + groups['server'] %}
{% for svc in hostvars[host]['services'] | default([]) if svc.check | default('none') != 'none' and svc.gatus | default(true) %}
  - name: "{{ svc.name }}"
    group: {{ host }}
{% if svc.gatus_url is defined %}
    url: "{{ svc.gatus_url }}"
{% else %}
    url: "{{ svc.check }}://{{ hostvars[host].ansible_host }}:{{ svc.port }}{{ svc.path | default('') }}"
{% endif %}
    interval: {{ svc.interval | default('5m') }}
{% if svc.check == 'tcp' %}
    conditions: *connected-conditions
{% elif svc.status is defined or svc.cert_expiry | default(false) %}
    conditions:
{% if svc.status is defined %}
      - "[STATUS] == {{ svc.status }}"
{% else %}
      - "[STATUS] < 400"
{% endif %}
{% if svc.cert_expiry | default(false) %}
      - "[CERTIFICATE_EXPIRATION] > {{ gatus_cert_min_expiry | default('336h') }}"
{% endif %}
{% else %}
    conditions: *http-conditions
{% endif %}
    alerts: *notify-all
{% endfor %}
{% endfor %}

  # --- docker-socket-proxy sidecars (every docker host except this one, which
  #     whats-up-docker reaches over the LAN; if a proxy dies WUD silently
  #     stops watching that host, so they get their own TCP checks) ---
{% for host in groups['nodes'] + groups['server'] if host != inventory_hostname and hostvars[host]['docker'] | default(false) %}
  - name: "docker-socket-proxy"
    group: {{ host }}
    url: "tcp://{{ hostvars[host].ansible_host }}:{{ docker_socket_proxy_port }}"
    interval: 5m
    conditions: *connected-conditions
    alerts: *notify-all
{% endfor %}

  # --- NFS server (roles server hosts with nfs_server: true, e.g. proxmox1) ---
  # Immich/media/media2/torrent/docker mount from here as nfs_client: true; a
  # wedged nfsd would stall those apps while the host still answers ICMP.
{% for host in groups['nodes'] + groups['server'] if hostvars[host]['nfs_server'] | default(false) %}
  - name: "{{ host }}-nfs-server"
    group: {{ host }}
    url: "tcp://{{ hostvars[host].ansible_host }}:2049"
    interval: 5m
    conditions: *connected-conditions
    alerts: *notify-all
{% endfor %}

  # --- Public DNS / TLS for the porkbun-ddns domain (roles/docker_host porkbun-ddns,
  #     caddy). Checked against public resolvers, not our own, so
  #     a broken porkbun-ddns update (expired API key, deleted record, etc.)
  #     shows up here.
  - name: porkbun-ddns-resolution
    group: docker
    url: "8.8.8.8:53"
    interval: 15m
    dns:
      query-name: "{{ porkbun_domain }}"
      query-type: "A"
    conditions:
      - "[DNS_RCODE] == NOERROR"
    alerts: *notify-all

  # TLS cert expiration on whatever Caddy serves for this domain. Runs over
  # the LAN path, but Caddy presents the same cert internally, so this still
  # catches a Let's Encrypt renewal failure before it visibly expires.
  - name: porkbun-ddns-cert
    group: docker
    url: "https://{{ gatus_cert_check_hostname | default(porkbun_domain) }}"
    interval: 1h
    conditions:
      - "[STATUS] < 500"
      - "[CERTIFICATE_EXPIRATION] > {{ gatus_cert_min_expiry | default('336h') }}"
    alerts: *notify-all

  # --- roles/kubernetes_control, roles/kubernetes_worker ---
  # kubeadm sets up the API server and kubelet with mTLS/token-gated endpoints, so these
  # are plain TCP-connect checks rather than HTTP health assertions.
  - name: kube-apiserver
    group: kubernetes
    url: "tcp://{{ hostvars[groups['kubernetes_control'][0]].ansible_host }}:6443"
    interval: 2m
    conditions: *connected-conditions
    alerts: *notify-all

  # etcd — a corrupt/unreachable etcd is a much nastier failure mode than a
  # dead kubelet, and TCP-connect is cheap to add alongside the checks above.
  - name: etcd
    group: kubernetes
    url: "tcp://{{ hostvars[groups['kubernetes_control'][0]].ansible_host }}:2379"
    interval: 5m
    conditions: *connected-conditions
    alerts: *notify-all

{% for host in groups['kubernetes_control'] + groups['kubernetes_workers'] %}
  - name: "kubelet-{{ host }}"
    group: kubernetes
    url: "tcp://{{ hostvars[host].ansible_host }}:10250"
    interval: 5m
    conditions: *connected-conditions
    alerts: *notify-all
{% endfor %}

  # --- roles/runner ---
  # GitLab Runner (shell executor) only polls gitlab.com outbound; it has no inbound
  # port to check. The "runner" node's ICMP ping in the [nodes] group above is the
  # only applicable check.
{% if gatus_cert_selftest | default(false) %}

  # --- ONE-OFF cert-expiry alert self-test ---
  # Rendered only when gatus_cert_selftest: true; proves a sub-threshold
  # CERTIFICATE_EXPIRATION reaches Signal. Does NOT create the endpoint — first
  # stand up a short-dated cert, e.g. on the target host:
  #   openssl req -x509 -newkey rsa:2048 -nodes -days 3 \
  #     -keyout /tmp/certtest.key -out /tmp/certtest.crt -subj "/CN=certtest.local"
  #   openssl s_server -cert /tmp/certtest.crt -key /tmp/certtest.key -www -accept 8443
  # gatus_cert_selftest_url defaults to https://127.0.0.1:8443 (s_server on the
  # docker host). The 3-day cert is < 336h, so it fires within ~90s. Afterwards:
  # set the flag false, re-run Ansible, stop s_server, remove the temp certs.
  - name: cert-expiry-selftest
    group: _test
    url: "{{ gatus_cert_selftest_url | default('https://127.0.0.1:8443') }}"
    interval: 30s
    client:
      insecure: true            # self-signed; we assert expiry, not chain validity
    conditions:
      - "[CERTIFICATE_EXPIRATION] > {{ gatus_cert_min_expiry | default('336h') }}"
    alerts:
      - type: signal            # deliberately Signal-only to validate that path
{% endif %}
