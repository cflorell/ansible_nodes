---
services:
  jellyseerr:
    image: ghcr.io/seerr-team/seerr:v3.3.0
    container_name: jellyseerr
    user: root
    environment:
      - LOG_LEVEL=debug
      - TZ=Europe/Stockholm
    ports:
      - 5055:5055
    volumes:
      - ./jellyseerr:/app/config
    restart: unless-stopped

  promtail:
    image: grafana/promtail:3.6.11
    container_name: promtail
    user: root
    volumes:
      - /var/log:/var/log
      - ./promtail:/etc/promtail
    restart: unless-stopped
    command: -config.file=/etc/promtail/promtail-config.yml

  tracearr:
    image: ghcr.io/connorgallopo/tracearr:1.5.0
    container_name: tracearr
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=production
      - PORT=3000
      - HOST=0.0.0.0
      - TZ=${TZ:-UTC}
      - DATABASE_URL=postgres://tracearr:{{ tracearr_postgres_password }}@timescale:5432/tracearr
      - REDIS_URL=redis://redis:6379
      - JWT_SECRET=${JWT_SECRET}
      - COOKIE_SECRET=${COOKIE_SECRET}
      - CORS_ORIGIN=${CORS_ORIGIN:-*}
      - LOG_LEVEL=${LOG_LEVEL:-info}
    depends_on:
      timescale:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - tracearr-network

  timescale:
    # Official TimescaleDB image with PostgreSQL 16
    # Note: TimescaleDB Toolkit is not included in the official image
    # For Toolkit support, use the supervised deployment instead
    image: timescale/timescaledb:2.28.3-pg16
    container_name: tracearr-db
    shm_size: 256mb  # Required for PostgreSQL shared memory
    # Allow unlimited tuple decompression for migrations on compressed hypertables
    command: postgres -c timescaledb.max_tuples_decompressed_per_dml_transaction=0
    environment:
      - POSTGRES_USER=tracearr
      - POSTGRES_PASSWORD={{ tracearr_postgres_password }}
      - POSTGRES_DB=tracearr
    volumes:
      - ./timescale_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U tracearr"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    networks:
      - tracearr-network

  redis:
    image: redis:8.8.0-alpine
    container_name: tracearr-redis
    command: redis-server --appendonly yes
    volumes:
      - ./redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    networks:
      - tracearr-network

  grimmory:
    image: grimmory/grimmory:latest
    container_name: grimmory
    environment:
      - USER_ID=${APP_USER_ID}
      - GROUP_ID=${APP_GROUP_ID}
      - TZ=${TZ}
      - DATABASE_URL=${DATABASE_URL}
      - DATABASE_USERNAME=${DB_USER}
      - DATABASE_PASSWORD=${DB_PASSWORD}
    depends_on:
      mariadb:
        condition: service_healthy
    ports:
      - "6060:6060"
    volumes:
      - ./grimmory/data:/app/data
      - /mnt/Storage3/samba/Ebooks:/books
      - ./grimmory/bookdrop:/bookdrop
    healthcheck:
      test: wget -q -O - http://localhost:6060/api/v1/healthcheck
      interval: 60s
      retries: 5
      start_period: 60s
      timeout: 10s
    restart: unless-stopped

  mariadb:
    image: lscr.io/linuxserver/mariadb:11.4.12
    container_name: mariadb
    environment:
      - PUID=${DB_USER_ID}
      - PGID=${DB_GROUP_ID}
      - TZ=${TZ}
      - MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD}
      - MYSQL_DATABASE=${MYSQL_DATABASE}
      - MYSQL_USER=${DB_USER}
      - MYSQL_PASSWORD=${DB_PASSWORD}
    volumes:
      - ./mariadb/config:/config
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "mariadb-admin", "ping", "-h", "localhost" ]
      interval: 5s
      timeout: 5s
      retries: 10

  sonarr:
    image: lscr.io/linuxserver/sonarr:4.0.19
    container_name: sonarr
    environment:
      - PUID=0
      - PGID=0
      - TZ=${TZ}
    ports:
      - "8989:8989"
    volumes:
      - ./sonarr:/config
      - /mnt/Storage2/Series:/tv/storage2
      - /mnt/Storage3/Series:/tv/storage3
      - /mnt/Storage3/A/Series:/tv/anime
      - /mnt/Storage3/Download:/downloads
    restart: unless-stopped

  radarr:
    image: lscr.io/linuxserver/radarr:6.3.0
    container_name: radarr
    environment:
      - PUID=0
      - PGID=0
      - TZ=${TZ}
    ports:
      - "7878:7878"
    volumes:
      - ./radarr:/config
      - /mnt/Storage1/UHD:/movies/uhd
      - /mnt/Storage4/HD:/movies/hd
      - /mnt/Storage3/A/Movies:/movies/anime
      - /mnt/Storage3/Download:/downloads
    restart: unless-stopped

  bazarr:
    image: lscr.io/linuxserver/bazarr:1.6.0
    container_name: bazarr
    environment:
      - PUID=0
      - PGID=0
      - TZ=${TZ}
    ports:
      - "6767:6767"
    volumes:
      - ./bazarr:/config
      - /mnt/Storage2/Series:/tv/storage2
      - /mnt/Storage3/Series:/tv/storage3
      - /mnt/Storage3/A/Series:/tv/anime
      - /mnt/Storage1/UHD:/movies/uhd
      - /mnt/Storage4/HD:/movies/hd
      - /mnt/Storage3/A/Movies:/movies/anime
    restart: unless-stopped

{% include "common/docker-socket-proxy.yml.j2" %}

networks:
  tracearr-network:
    driver: bridge
