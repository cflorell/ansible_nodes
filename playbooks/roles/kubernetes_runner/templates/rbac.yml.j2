---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ kubernetes_runner_namespace }}

---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: gitlab-runner
  namespace: {{ kubernetes_runner_namespace }}

---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: gitlab-runner
  namespace: {{ kubernetes_runner_namespace }}
rules:
  - apiGroups: [""]
    resources: ["configmaps", "pods", "pods/log", "secrets", "services"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["pods/exec", "pods/attach"]
    verbs: ["get", "create", "patch", "delete"]
  - apiGroups: [""]
    resources: ["events"]
    verbs: ["get", "list", "watch"]

---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: gitlab-runner
  namespace: {{ kubernetes_runner_namespace }}
subjects:
  - kind: ServiceAccount
    name: gitlab-runner
    namespace: {{ kubernetes_runner_namespace }}
roleRef:
  kind: Role
  name: gitlab-runner
  apiGroup: rbac.authorization.k8s.io
