---
skip_list:
  - name[casing]
  - name[template]
  - latest[git]
  - var-naming[no-role-prefix]
  - command-instead-of-module

exclude_paths:
  - playbooks/group_vars/all/secrets.sops.yaml

# Molecule scenario vars files are variables, not playbooks — otherwise
# ansible-lint tries to parse them as a list of plays.
kinds:
  - vars: "molecule/*/vars.yml"
