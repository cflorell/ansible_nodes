[workstation]
workstation-test ansible_connection=local ansible_user=runner

[server]
proxmox1 ansible_host=192.0.2.10 ansible_user=root ansible_port=22
proxmox2 ansible_host=192.0.2.11 ansible_user=root ansible_port=22

[nodes]
docker ansible_host=192.0.2.20 ansible_user=root ansible_port=22
authentik ansible_host=192.0.2.21 ansible_user=root ansible_port=22
immich ansible_host=192.0.2.22 ansible_user=root ansible_port=22
prometheus-grafana ansible_host=192.0.2.23 ansible_user=root ansible_port=22
media ansible_host=192.0.2.24 ansible_user=root ansible_port=22
torrent ansible_host=192.0.2.26 ansible_user=root ansible_port=22
media2 ansible_host=192.0.2.27 ansible_user=root ansible_port=22
runner ansible_host=192.0.2.28 ansible_user=root ansible_port=22

[kubernetes:children]
kubernetes_control
kubernetes_workers

[kubernetes_control]
kubernetes-control ansible_host=192.0.2.30 ansible_user=root ansible_port=22

[kubernetes_workers]
kubernetes-node1 ansible_host=192.0.2.31 ansible_user=root ansible_port=22
kubernetes-node2 ansible_host=192.0.2.32 ansible_user=root ansible_port=22
kubernetes-node3 ansible_host=192.0.2.33 ansible_user=root ansible_port=22

[server:vars]
ansible_ssh_private_key_file=~/.ssh/id_ed25519

[nodes:vars]
ansible_ssh_private_key_file=~/.ssh/id_ed25519
